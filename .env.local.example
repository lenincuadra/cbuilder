# Copy this file to .env.local (gitignored) and fill in your Supabase project values.
# Project settings -> API: "Project URL" and the "anon public" key.
# Without these, the app falls back to per-browser localStorage (not durable).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
